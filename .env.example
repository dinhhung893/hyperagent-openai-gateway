# Copy to .env and adjust. Do NOT commit .env (it is gitignored).

# Upstream: "mcp" (real Hyperagent) or "mock" (offline)
GATEWAY_UPSTREAM=mock

# Real upstream settings (used when GATEWAY_UPSTREAM=mcp)
HYPERAGENT_MCP_URL=https://hyperagent.com/api/mcp
HYPERAGENT_TOKEN_FILE=~/.hyperagent-gateway/tokens.json

# Client-facing API keys (comma-separated). Empty = dev mode (accept any key).
SHIM_API_KEYS=sk-changeme

# Optional
GATEWAY_DEFAULT_AGENT=
GATEWAY_POLL_INTERVAL=1.0
GATEWAY_RUN_TIMEOUT=600
GATEWAY_DISABLED_TOOLS=
GATEWAY_STATE_PATH=~/.hyperagent-gateway/state.db
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
